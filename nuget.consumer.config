<?xml version="1.0" encoding="utf-8"?>
<!--
  Copy this file to your consumer application's solution root as nuget.config.
  It tells NuGet to look for HopDev.Maui.Controls in the local feed first.
  
  After testing is complete, remove the LocalNuGet source and 
  packageSourceMapping to switch back to nuget.org.
-->
<configuration>
  <packageSources>
    <add key="LocalNuGet" value="D:\DATA\LocalNuGet" />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>

  <packageSourceMapping>
    <packageSource key="LocalNuGet">
      <package pattern="HopDev.Maui.Controls" />
    </packageSource>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
