<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HopDev.Maui.Controls.Sample.Pages.TitleBarTestPage"
             BackgroundColor="{DynamicResource PageBackground}"
             Title="TitleBar">

    <ScrollView Padding="20">
        <VerticalStackLayout Spacing="16">

            <Label Text="TitleBar Diagnostics" FontSize="24" FontAttributes="Bold"
                   TextColor="{DynamicResource TextPrimary}" />

            <!-- Theme Toggle Card -->
            <Border Stroke="{DynamicResource CardBorder}" StrokeThickness="1"
                    BackgroundColor="{DynamicResource CardBackground}" Padding="16"
                    StrokeShape="RoundRectangle 8">
                <VerticalStackLayout Spacing="12">
                    <Label Text="App Theme" FontSize="18" FontAttributes="Bold"
                           TextColor="{DynamicResource TextPrimary}" />
                    <HorizontalStackLayout Spacing="8">
                        <Button Text="🌙 Dark" Clicked="OnThemeDark"
                                BackgroundColor="{DynamicResource CardBorder}"
                                TextColor="{DynamicResource TextPrimary}" FontSize="13" Padding="12,6" />
                        <Button Text="☀️ Light" Clicked="OnThemeLight"
                                BackgroundColor="{DynamicResource CardBorder}"
                                TextColor="{DynamicResource TextPrimary}" FontSize="13" Padding="12,6" />
                    </HorizontalStackLayout>
                    <Label x:Name="LblTheme" FontSize="13" TextColor="{DynamicResource TextMuted}"
                           Text="Current: Dark" />
                </VerticalStackLayout>
            </Border>

            <!-- Platform Status Card -->
            <Border Stroke="{DynamicResource CardBorder}" StrokeThickness="1"
                    BackgroundColor="{DynamicResource CardBackground}" Padding="16"
                    StrokeShape="RoundRectangle 8">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Platform Status" FontSize="18" FontAttributes="Bold"
                           TextColor="{DynamicResource TextPrimary}" />
                    <Label x:Name="LblAttached" FontSize="14" TextColor="{DynamicResource TextSecondary}" />
                    <Label x:Name="LblCaptionInsets" FontSize="14" TextColor="{DynamicResource TextSecondary}" />
                    <Label x:Name="LblScale" FontSize="14" TextColor="{DynamicResource TextSecondary}" />
                </VerticalStackLayout>
            </Border>

            <!-- Caption Button Themes Card -->
            <Border Stroke="{DynamicResource CardBorder}" StrokeThickness="1"
                    BackgroundColor="{DynamicResource CardBackground}" Padding="16"
                    StrokeShape="RoundRectangle 8">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Caption Button Themes" FontSize="18" FontAttributes="Bold"
                           TextColor="{DynamicResource TextPrimary}" />
                    <Label Text="Changes Min/Max/Close button appearance. Hover to see the effect."
                           FontSize="13" TextColor="{DynamicResource TextMuted}" />
                    <HorizontalStackLayout Spacing="8">
                        <Button Text="Default" Clicked="OnThemeDefault"
                                BackgroundColor="{DynamicResource CardBorder}"
                                TextColor="{DynamicResource TextPrimary}" FontSize="13" Padding="12,6" />
                        <Button Text="Blue Accent" Clicked="OnThemeBlue"
                                BackgroundColor="#1D4ED8"
                                TextColor="White" FontSize="13" Padding="12,6" />
                        <Button Text="Green Accent" Clicked="OnThemeGreen"
                                BackgroundColor="#15803D"
                                TextColor="White" FontSize="13" Padding="12,6" />
                    </HorizontalStackLayout>
                    <Label x:Name="LblLastAction" FontSize="14" TextColor="{DynamicResource SuccessText}"
                           Text="No actions yet" />
                </VerticalStackLayout>
            </Border>

            <!-- Architecture Card -->
            <Border Stroke="{DynamicResource CardBorder}" StrokeThickness="1"
                    BackgroundColor="{DynamicResource CardBackground}" Padding="16"
                    StrokeShape="RoundRectangle 8">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Borderless Window Recipe" FontSize="18" FontAttributes="Bold"
                           TextColor="{DynamicResource TextPrimary}" />
                    <Label FontSize="13" TextColor="{DynamicResource TextSecondary}"
                           Text="Three things make a borderless MAUI window on Windows:" />
                    <Label FontSize="13" TextColor="{DynamicResource TextSecondary}"
                           Text="1. MauiProgram: UseBorderlessWindow() — extends content, hides icon, -32px margin, DWM border color" />
                    <Label FontSize="13" TextColor="{DynamicResource TextSecondary}"
                           Text="2. App.xaml.cs: Title = &quot;&quot; — prevents native title text" />
                    <Label FontSize="13" TextColor="{DynamicResource TextSecondary}"
                           Text="3. Platforms/Windows/App.xaml: WindowCaptionBackground = Transparent" />
                    <Label FontSize="13" TextColor="{DynamicResource TextMuted}"
                           Text="The 1px top border is a DWM limitation (WinUI#6901). It can be recolored via DwmSetWindowAttribute(DWMWA_BORDER_COLOR) but not removed." />
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
