<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:hd="clr-namespace:HopDev.Maui.Controls.Controls;assembly=HopDev.Maui.Controls"
             xmlns:controls="clr-namespace:HopDev.Maui.Controls.Sample.Controls"
             x:Class="HopDev.Maui.Controls.Sample.AppLayout"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{DynamicResource PageBackground}">

    <AbsoluteLayout>

        <!-- ═══ MAIN LAYOUT ═══ -->
        <Grid AbsoluteLayout.LayoutBounds="0,0,1,1"
              AbsoluteLayout.LayoutFlags="All"
              RowDefinitions="Auto,*"
              ColumnDefinitions="Auto,*,Auto"
              BackgroundColor="{DynamicResource PageBackground}">

            <!-- ═══ ROW 0: TITLE BAR (spans all columns) ═══
                 58px matches the visual weight of sidebar items. -->
            <hd:TitleBar x:Name="AppTitleBar"
                         Grid.Row="0" Grid.ColumnSpan="3"
                         HeightRequest="58"
                         TitleBarBackground="{DynamicResource SurfaceColor}"
                         ButtonForegroundColor="{DynamicResource TextSecondary}"
                         ButtonHoverColor="{DynamicResource AccentHover}"
                         AttachedToWindow="OnTitleBarAttached">

                <hd:TitleBar.LeadingContent>
                    <HorizontalStackLayout Spacing="0" Padding="0">
                        <!-- Brand section — width matches left sidebar -->
                        <Border StrokeThickness="0" BackgroundColor="Transparent"
                                WidthRequest="160" Padding="12,0">
                            <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                                <Border StrokeShape="RoundRectangle 6"
                                        BackgroundColor="{DynamicResource ButtonPrimaryBackground}"
                                        Padding="4,2" HeightRequest="32" WidthRequest="32">
                                    <Label Text="&#xEA18;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="20" TextColor="{DynamicResource ButtonPrimaryText}"
                                           HorizontalOptions="Center" VerticalOptions="Center" />
                                </Border>
                                <Label Text="Cloud" FontSize="17" FontAttributes="Bold"
                                       TextColor="{DynamicResource TextPrimary}" VerticalOptions="Center" />
                            </HorizontalStackLayout>
                        </Border>

                        <!-- Menu items — 18px icons + 15px labels, matching sidebar proportions -->
                        <HorizontalStackLayout Spacing="2" hd:TitleBar.IsInteractive="True">
                            <!-- Tests & Utilities: hover + click wired in code-behind -->
                            <Border x:Name="MenuTests" Padding="14,10" StrokeThickness="0"
                                    BackgroundColor="Transparent" StrokeShape="RoundRectangle 4">
                                <HorizontalStackLayout Spacing="8">
                                    <Label Text="&#xE7FC;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                           TextColor="{DynamicResource TextSecondary}" VerticalOptions="Center" />
                                    <Label Text="Tests ▾" FontSize="15"
                                           TextColor="{DynamicResource TextSecondary}" VerticalOptions="Center" />
                                </HorizontalStackLayout>
                            </Border>
                            <Border x:Name="MenuUtilities" Padding="14,10" StrokeThickness="0"
                                    BackgroundColor="Transparent" StrokeShape="RoundRectangle 4">
                                <HorizontalStackLayout Spacing="8">
                                    <Label Text="&#xE90F;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                           TextColor="{DynamicResource TextSecondary}" VerticalOptions="Center" />
                                    <Label Text="Utilities ▾" FontSize="15"
                                           TextColor="{DynamicResource TextSecondary}" VerticalOptions="Center" />
                                </HorizontalStackLayout>
                            </Border>
                            <Border x:Name="MenuSettings" Padding="14,10" StrokeThickness="0"
                                    BackgroundColor="Transparent" StrokeShape="RoundRectangle 4">
                                <HorizontalStackLayout Spacing="8">
                                    <Label Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                           TextColor="{DynamicResource TextSecondary}" VerticalOptions="Center" />
                                    <Label Text="Settings" FontSize="15"
                                           TextColor="{DynamicResource TextSecondary}" VerticalOptions="Center" />
                                </HorizontalStackLayout>
                            </Border>
                            <Border x:Name="MenuAbout" Padding="14,10" StrokeThickness="0"
                                    BackgroundColor="Transparent" StrokeShape="RoundRectangle 4">
                                <HorizontalStackLayout Spacing="8">
                                    <Label Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                           TextColor="{DynamicResource TextSecondary}" VerticalOptions="Center" />
                                    <Label Text="About" FontSize="15"
                                           TextColor="{DynamicResource TextSecondary}" VerticalOptions="Center" />
                                </HorizontalStackLayout>
                            </Border>
                        </HorizontalStackLayout>
                    </HorizontalStackLayout>
                </hd:TitleBar.LeadingContent>

                <hd:TitleBar.TrailingContent>
                    <HorizontalStackLayout Spacing="8" Padding="0,0,8,0">
                        <Button Text="&#xEA8F;" FontFamily="Segoe MDL2 Assets"
                                FontSize="18" Padding="8,4"
                                BackgroundColor="Transparent"
                                TextColor="{DynamicResource TextSecondary}" />
                        <Border StrokeShape="RoundRectangle 15"
                                BackgroundColor="{DynamicResource ButtonPrimaryBackground}"
                                Padding="0" HeightRequest="30" WidthRequest="30"
                                hd:TitleBar.IsInteractive="True">
                            <Label Text="U" FontSize="14" FontAttributes="Bold"
                                   TextColor="{DynamicResource ButtonPrimaryText}"
                                   HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>
                    </HorizontalStackLayout>
                </hd:TitleBar.TrailingContent>
            </hd:TitleBar>

            <!-- ═══ ROW 1, COL 0: LEFT SIDEBAR ═══ -->
            <Border Grid.Row="1" Grid.Column="0"
                    BackgroundColor="{DynamicResource SurfaceColor}"
                    StrokeThickness="0" Padding="0">
                <Grid RowDefinitions="*,Auto,Auto">
                    <VerticalStackLayout x:Name="SidebarItems" Spacing="2" Padding="4,8" />
                    <VerticalStackLayout x:Name="SidebarBottomItems" Grid.Row="1"
                                         Spacing="2" Padding="4,0,4,4" />
                    <Border Grid.Row="2" Padding="4,4" StrokeThickness="0"
                            BackgroundColor="Transparent">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnToggleSidebar" />
                        </Border.GestureRecognizers>
                        <Label x:Name="CollapseIcon" Text="◀" FontSize="12"
                               TextColor="{DynamicResource TextMuted}"
                               HorizontalOptions="Center" />
                    </Border>
                </Grid>
            </Border>
            <BoxView Grid.Row="1" Grid.Column="0" WidthRequest="1"
                     HorizontalOptions="End" Color="{DynamicResource CardBorder}" />

            <!-- ═══ ROW 1, COL 1: CONTENT ═══ -->
            <ContentView x:Name="PageHost" Grid.Row="1" Grid.Column="1" />

            <!-- ═══ ROW 1, COL 2: RIGHT KEY PANEL ═══ -->
            <Border Grid.Row="1" Grid.Column="2"
                    BackgroundColor="{DynamicResource SurfaceColor}"
                    StrokeThickness="0" Padding="0">
                <Grid RowDefinitions="Auto,*,Auto" Padding="12,12">
                    <VerticalStackLayout Spacing="6">
                        <HorizontalStackLayout Spacing="6">
                            <Label Text="&#xE8D7;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="18" TextColor="{DynamicResource TextSecondary}"
                                   VerticalOptions="Center" />
                            <Label Text="Keys" FontSize="16" FontAttributes="Bold"
                                   TextColor="{DynamicResource TextPrimary}"
                                   VerticalOptions="Center" />
                        </HorizontalStackLayout>
                        <Label Text="Key Management →" FontSize="13"
                               TextColor="{DynamicResource ButtonPrimaryBackground}"
                               TextDecorations="Underline">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnKeyManagementTapped" />
                            </Label.GestureRecognizers>
                        </Label>
                        <BoxView HeightRequest="1" Color="{DynamicResource CardBorder}"
                                 Margin="0,4" />
                    </VerticalStackLayout>
                    <VerticalStackLayout x:Name="KeyPanelCards" Grid.Row="1"
                                         Spacing="8" Padding="0,4" />
                    <Label Grid.Row="2" Text="" />
                </Grid>
            </Border>
            <BoxView Grid.Row="1" Grid.Column="2" WidthRequest="1"
                     HorizontalOptions="Start" Color="{DynamicResource CardBorder}" />
        </Grid>

        <!-- ═══ RESIZE GRIP ═══ -->
        <controls:ResizeGrip AbsoluteLayout.LayoutBounds="1,1,20,20"
                             AbsoluteLayout.LayoutFlags="PositionProportional" />

        <!-- ═══ DROPDOWN OVERLAY ═══ -->
        <AbsoluteLayout x:Name="DropdownOverlay"
                         AbsoluteLayout.LayoutBounds="0,0,1,1"
                         AbsoluteLayout.LayoutFlags="All"
                         InputTransparent="True"
                         CascadeInputTransparent="False"
                         IsVisible="False">

            <!-- Dismiss backdrop — starts below title bar (y=58) -->
            <BoxView x:Name="DropdownBackdrop"
                     AbsoluteLayout.LayoutBounds="0,58,1,1"
                     AbsoluteLayout.LayoutFlags="SizeProportional"
                     Color="Transparent"
                     InputTransparent="False">
                <BoxView.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnDropdownDismiss" />
                </BoxView.GestureRecognizers>
            </BoxView>

            <!-- Dropdown menu panel -->
            <Border x:Name="DropdownMenu"
                    BackgroundColor="{DynamicResource CardBackground}"
                    Stroke="{DynamicResource CardBorder}"
                    StrokeShape="RoundRectangle 6" Padding="4"
                    HorizontalOptions="Start" VerticalOptions="Start"
                    InputTransparent="False">
                <VerticalStackLayout x:Name="DropdownItems" Spacing="0" />
            </Border>
        </AbsoluteLayout>

    </AbsoluteLayout>
</ContentPage>
